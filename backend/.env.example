# -------------------------------------------------------
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# -------------------------------------------------------

# --- HuggingFace Inference API ---
# Get your token from: https://huggingface.co/settings/tokens
# The token must have "Inference Providers" or "read" permission.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Embedding model (must support feature-extraction on HF Inference API)
# Default: sentence-transformers/all-MiniLM-L6-v2  (384-dim, free tier)
# Other options: BAAI/bge-small-en-v1.5, thenlper/gte-small
# NOTE: If you change this, update FAISS_DIM in rag_service.py accordingly.
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Chat/LLM model (must support text-generation / chat_completion on HF Inference API)
# Default: mistralai/Mistral-7B-Instruct-v0.3
# Other options: meta-llama/Meta-Llama-3-8B-Instruct, HuggingFaceH4/zephyr-7b-beta
CHAT_MODEL=meta-llama/Llama-3.1-8B-Instruct:novita

# --- CORS ---
# Comma-separated list of allowed frontend origins.
# In production, set this to your actual domain(s).
# Example: https://myapp.com,https://www.myapp.com
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# --- Cleanup ---
# Auto-delete conversations not updated in this many days. Set to 0 to disable.
CONVERSATION_RETENTION_DAYS=10

# --- RAG Retrieval ---
# Number of chunks fetched from the knowledge base per query.
# Higher = better recall but more context sent to the LLM. Default: 6
RAG_TOP_K=6